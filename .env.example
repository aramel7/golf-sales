# 데이터베이스 연결 주소 (Render PostgreSQL에서 복사)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT 비밀키 (임의의 긴 문자열로 변경하세요)
JWT_SECRET=change-this-to-a-long-random-string-1234567890

# 최초 관리자 계정 (첫 실행 시 자동 생성)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=golf1234

# 서버 포트 (Render에서는 자동 설정됨)
PORT=3000

# 환경 (production 또는 development)
NODE_ENV=production
